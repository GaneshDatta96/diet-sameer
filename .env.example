# ---------------------------------------------------------------------------
# Gut Freedom · 7-Day Meal Plan Tool
# Copy this file to `.env.local`. Everything works with NO keys set (mock
# payment, offline plan generator, console "email") so you can review the flow
# immediately. Add keys to switch on the real integrations.
# ---------------------------------------------------------------------------

# Public site config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BOOK_CALL_URL=https://www.sameerdossani.net/BookNow

# Pricing (display + charge)
NEXT_PUBLIC_PRICE_AMOUNT=10
NEXT_PUBLIC_PRICE_CURRENCY=usd
NEXT_PUBLIC_PRICE_LABEL=$10

# Delivery "crafting" delay. Production defaults to 8-12 hours.
# For local testing, set these small (e.g. 1 and 2) to see delivery fast.
# DELIVERY_MIN_MINUTES=480
# DELIVERY_MAX_MINUTES=720

# --- Payments: Stripe (optional) -------------------------------------------
# Leave STRIPE_SECRET_KEY blank to use mock checkout.
# STRIPE_SECRET_KEY=sk_test_xxx
# Optional: use a pre-made Price instead of inline price_data
# STRIPE_PRICE_ID=price_xxx

# --- AI generation: OpenAI (optional) --------------------------------------
# Leave blank to use the built-in rules-based generator.
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o-mini

# --- Email delivery: Resend (required in production) -------------------------
# Personalized plan emails are sent via Resend (scheduled_at for the 8-12h delay).
# Kajabi handles payment + CRM; Resend delivers the dynamic meal plan.
# RESEND_API_KEY=re_xxx
# RESEND_FROM=Sameer Dossani <hello@sameerdossani.net>

# --- Kajabi (payments + CRM) -------------------------------------------------
# When set, checkout redirects to your Kajabi offer instead of Stripe.
# KAJABI_OFFER_CHECKOUT_URL=https://yoursite.mykajabi.com/offers/XXXXX/checkout
# KAJABI_OFFER_ID=12345
# KAJABI_WEBHOOK_SECRET=change-me
# Webhook URL: https://your-app.vercel.app/api/kajabi/webhook?secret=change-me
# Post-purchase redirect in Kajabi: https://your-app.vercel.app/confirm?orderId=ORDER_ID&kajabi=1
#   (use your app's URL; orderId is passed via checkout query param order_id)
#
# Optional API sync (Settings → Public API in Kajabi):
# KAJABI_CLIENT_ID=
# KAJABI_CLIENT_SECRET=
# KAJABI_SITE_ID=
# KAJABI_TAG_ID=          # tag contacts after purchase (e.g. meal-plan-buyer)

# --- Upstash Redis (required in production on Vercel) ----------------------
# Add Redis from Vercel Marketplace (Storage). Vercel auto-injects:
# UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN

# Allow the /api/preview sample endpoint in production (off by default)
# ALLOW_PREVIEW=0
