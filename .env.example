# ---------------------------------------------------------------------------
# Gut Freedom · 7-Day Meal Plan Tool
# Copy this file to `.env.local`. Everything works with NO keys set (mock
# payment, offline plan generator, console "email") so you can review the flow
# immediately. Add keys to switch on the real integrations.
# ---------------------------------------------------------------------------

# Public site config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BOOK_CALL_URL=https://www.sameerdossani.net/BookNow

# Pricing (display + charge)
NEXT_PUBLIC_PRICE_AMOUNT=10
NEXT_PUBLIC_PRICE_CURRENCY=usd
NEXT_PUBLIC_PRICE_LABEL=$10

# --- Test mode (current defaults) --------------------------------------------
# Paywall is OFF and plans send immediately. Set SKIP_PAYWALL=0 to re-enable.
# NEXT_PUBLIC_SKIP_PAYWALL=1
# SKIP_PAYWALL=1

# Delivery delay (minutes). 0 = send right away. Production: 480–720 (8–12h).
DELIVERY_MIN_MINUTES=0
DELIVERY_MAX_MINUTES=0

# --- Email: SMTP / Gmail ---------------------------------------------------
# Option A — simple vars (recommended):
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# GMAIL_FROM=Gut Freedom <you@gmail.com>
#
# Option B — JSON array (uses first account):
# GMAIL_ACCOUNTS_JSON=[{"email":"you@gmail.com","password":"app-password","smtp":"smtp.gmail.com","port":587}]
#
# Option C — generic SMTP:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=app-password
# SMTP_FROM=Gut Freedom <you@gmail.com>

# --- Email: Resend (production alternative) ----------------------------------
# RESEND_API_KEY=re_xxx
# RESEND_FROM=Sameer Dossani <hello@sameerdossani.net>

# --- Payments: Stripe (optional) -------------------------------------------
# Leave STRIPE_SECRET_KEY blank while SKIP_PAYWALL=1.
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_PRICE_ID=price_xxx

# --- AI generation: OpenAI (optional) --------------------------------------
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o-mini

# --- Kajabi (payments + CRM) — disabled while SKIP_PAYWALL=1 -----------------
# KAJABI_OFFER_CHECKOUT_URL=https://yoursite.mykajabi.com/offers/XXXXX/checkout
# KAJABI_OFFER_ID=12345
# KAJABI_WEBHOOK_SECRET=change-me
# KAJABI_CLIENT_ID=
# KAJABI_CLIENT_SECRET=
# KAJABI_SITE_ID=
# KAJABI_TAG_ID=

# --- Upstash Redis (required on Vercel) ------------------------------------
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Allow the /api/preview sample endpoint in production (off by default)
# ALLOW_PREVIEW=0
