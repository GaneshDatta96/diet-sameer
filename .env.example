# ---------------------------------------------------------------------------
# Gut Freedom · 7-Day Meal Plan Tool
# Copy this file to `.env.local`. Everything works with NO keys set (mock
# payment, offline plan generator, console "email") so you can review the flow
# immediately. Add keys to switch on the real integrations.
# ---------------------------------------------------------------------------

# Public site config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BOOK_CALL_URL=https://www.sameerdossani.net/BookNow

# Pricing (display + charge)
NEXT_PUBLIC_PRICE_AMOUNT=10
NEXT_PUBLIC_PRICE_CURRENCY=usd
NEXT_PUBLIC_PRICE_LABEL=$10

# Delivery "crafting" delay. Production defaults to 8-12 hours.
# For local testing, set these small (e.g. 1 and 2) to see delivery fast.
# DELIVERY_MIN_MINUTES=480
# DELIVERY_MAX_MINUTES=720

# --- Payments: Stripe (optional) -------------------------------------------
# Leave STRIPE_SECRET_KEY blank to use mock checkout.
# STRIPE_SECRET_KEY=sk_test_xxx
# Optional: use a pre-made Price instead of inline price_data
# STRIPE_PRICE_ID=price_xxx

# --- AI generation: OpenAI (optional) --------------------------------------
# Leave blank to use the built-in rules-based generator.
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o-mini

# --- Email delivery: Resend (optional) -------------------------------------
# Leave blank to log emails to the server console instead of sending.
# RESEND_API_KEY=re_xxx
# RESEND_FROM=Sameer Dossani <hello@sameerdossani.net>

# --- Delivery cron protection ----------------------------------------------
# Set a secret and pass ?secret=... (or Bearer header) to /api/cron/deliver
# CRON_SECRET=change-me

# Allow the /api/preview sample endpoint in production (off by default)
# ALLOW_PREVIEW=0

# --- Cloudflare Workers (production) ---------------------------------------
# Create a KV namespace and set its id in wrangler.jsonc:
#   npx wrangler kv namespace create ORDER_STORE
# Set env vars in the Cloudflare dashboard or via `wrangler secret put`.
# Schedule /api/cron/deliver every 15 minutes for delayed email delivery.
